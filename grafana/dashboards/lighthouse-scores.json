      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 8 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Performance"    }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue"   } }] },
          { "matcher": { "id": "byName", "options": "Accessibility"  }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green"  } }] },
          { "matcher": { "id": "byName", "options": "Best Practices" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
          { "matcher": { "id": "byName", "options": "SEO"            }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "purple" } }] }
        ]
      },
      "datasource": { "type": "testdata" },
      "targets": [
        { "refId": "A", "scenarioId": "random_walk", "alias": "Performance",    "min": 88, "max": 100, "startValue": 96 },
        { "refId": "B", "scenarioId": "random_walk", "alias": "Accessibility",  "min": 90, "max": 100, "startValue": 98 },
        { "refId": "C", "scenarioId": "random_walk", "alias": "Best Practices", "min": 85, "max": 100, "startValue": 95 },
        { "refId": "D", "scenarioId": "random_walk", "alias": "SEO",            "min": 90, "max": 100, "startValue": 100 }
