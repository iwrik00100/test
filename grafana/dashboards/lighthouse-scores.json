{
  "id": null,
  "uid": "netops-lighthouse",
  "title": "NetOps Cockpit — Lighthouse Scores",
  "description": "Performance, Accessibility, Best Practices and SEO scores over time",
  "tags": ["netops", "lighthouse", "performance"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1h",
  "time": { "from": "now-30d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "Performance",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 50   },
              { "color": "green",  "value": 90   }
            ]
          }
        }
      },
      "datasource": { "type": "testdata" },
      "targets": [
        {
          "refId": "A", "scenarioId": "random_walk",
          "alias": "Performance", "min": 88, "max": 100, "startValue": 96
        }
      ]
    },
    {
