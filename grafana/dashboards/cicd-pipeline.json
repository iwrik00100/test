{
  "id": null,
  "uid": "netops-cicd",
  "title": "NetOps Cockpit — CI/CD Pipeline Health",
  "description": "GitHub Actions pipeline metrics — build success rate, deploy frequency, lead time",
  "tags": ["netops", "cicd", "devops"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5m",
  "time": { "from": "now-7d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Pipeline Status",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "✅ Passing", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "❌ Failing", "color": "red"   } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1    }
            ]
          }
        }
      },
      "datasource": { "type": "testdata" },
      "targets": [
        {
          "refId": "A",
          "scenarioId": "random_walk",
          "alias": "Pipeline",
          "min": 0, "max": 1, "startValue": 1
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Deployments (7d)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "unit": "short"
        }
      },
      "datasource": { "type": "testdata" },
      "targets": [
        {
          "refId": "A",
          "scenarioId": "random_walk",
          "alias": "Deploys",
          "min": 0, "max": 3, "startValue": 1
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Build Success Rate",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["mean"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 80   },
              { "color": "green",  "value": 95   }
            ]
          }
        }
      },
      "datasource": { "type": "testdata" },
      "targets": [
        {
          "refId": "A",
          "scenarioId": "random_walk",
          "alias": "Success %",
          "min": 85, "max": 100, "startValue": 98
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Avg Lead Time (min)",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["mean"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "m",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 10   },
              { "color": "red",    "value": 20   }
            ]
          }
        }
      },
      "datasource": { "type": "testdata" },
      "targets": [
        {
          "refId": "A",
          "scenarioId": "random_walk",
          "alias": "Lead Time",
          "min": 2, "max": 8, "startValue": 4
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Pipeline Runs Over Time",
      "gridPos": { "x": 0, "y": 4, "w": 16, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Failed" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Passed" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          }
        ]
      },
      "datasource": { "type": "testdata" },
      "targets": [
        {
          "refId": "A", "scenarioId": "random_walk",
          "alias": "Passed", "min": 0, "max": 5, "startValue": 3
        },
        {
          "refId": "B", "scenarioId": "random_walk",
          "alias": "Failed", "min": 0, "max": 2, "startValue": 0
        }
      ]
    }
  ]
}
